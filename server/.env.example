# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/mediai

# JWT Secret Key
JWT_SECRET=mediai_jwt_secret_2024_change_in_production

# Server Port
PORT=5000

# Groq API Key (for disease prediction, report analysis, home remedies)
# Get your free key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Mistral AI API Key (for chatbot)
# Get your key from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here

# Razorpay Keys (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder_secret

# Email (for notifications - optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Admin Default Credentials
ADMIN_EMAIL=

